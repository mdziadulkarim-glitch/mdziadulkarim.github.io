import { useEffect, useState } from 'react';

function App() {
  const [profile, setProfile] = useState({});
  const [education, setEducation] = useState([]);
  const [experience, setExperience] = useState([]);
  const [publications, setPublications] = useState([]);
  const [projects, setProjects] = useState([]);
  const [skills, setSkills] = useState({});
  const [affiliations, setAffiliations] = useState([]);

  useEffect(() => {
    fetch('/data/profile.json').then(res => res.json()).then(setProfile);
    fetch('/data/education.json').then(res => res.json()).then(setEducation);
    fetch('/data/experience.json').then(res => res.json()).then(setExperience);
    fetch('/data/publications.json').then(res => res.json()).then(setPublications);
    fetch('/data/projects.json').then(res => res.json()).then(setProjects);
    fetch('/data/skills.json').then(res => res.json()).then(setSkills);
    fetch('/data/affiliations.json').then(res => res.json()).then(setAffiliations);
  }, []);

  return (
    <>
      <nav className="navbar">
        <div className="container nav-content">
          <h3>{profile.name}</h3>

          <div className="nav-links">
            <a href="#about">About</a>
            <a href="#education">Education</a>
            <a href="#experience">Experience</a>
            <a href="#publications">Publications</a>
            <a href="#projects">Projects</a>
            <a href="#contact">Contact</a>
          </div>
        </div>
      </nav>

      <section className="hero">
        <div className="container hero-content">
          <div>
            <h1>{profile.name}</h1>
            <h2>{profile.title}</h2>
            <p>{profile.about}</p>

            <div className="button-group">
              <a className="btn btn-primary" href="/cv.pdf">
                Download CV
              </a>

              <a className="btn btn-secondary" href="#contact">
                Contact Me
              </a>
            </div>
          </div>

          <img
            src="/profile.jpg"
            alt="profile"
            className="profile-image"
          />
        </div>
      </section>

      <section id="about">
        <div className="container">
          <h2 className="section-title">About</h2>

          <div className="card">
            <p>{profile.about}</p>
          </div>
        </div>
      </section>

      <section id="education">
        <div className="container">
          <h2 className="section-title">Education</h2>

          {education.map((item, index) => (
            <div className="card" key={index}>
              <h3>{item.degree}</h3>
              <p>{item.institution}</p>
              <p>{item.year}</p>
            </div>
          ))}
        </div>
      </section>

      <section id="experience">
        <div className="container">
          <h2 className="section-title">Experience</h2>

          {experience.map((item, index) => (
            <div className="card" key={index}>
              <h3>{item.position}</h3>
              <p>
                {item.organization} | {item.duration}
              </p>

              <ul>
                {item.details.map((detail, i) => (
                  <li key={i}>{detail}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <section id="publications">
        <div className="container">
          <h2 className="section-title">Publications</h2>

          {publications.map((paper, index) => (
            <div className="card" key={index}>
              <h3>{paper.title}</h3>
              <p>
                {paper.publisher} | {paper.conference} | {paper.year}
              </p>

              <a href={paper.doi} target="_blank">
                View Publication
              </a>
            </div>
          ))}
        </div>
      </section>

      <section id="projects">
        <div className="container">
          <h2 className="section-title">Projects</h2>

          {projects.map((project, index) => (
            <div className="card" key={index}>
              <h3>{project.title}</h3>
              <p>{project.technology}</p>
              <p>{project.description}</p>
            </div>
          ))}
        </div>
      </section>

      <section id="skills">
        <div className="container">
          <h2 className="section-title">Skills</h2>

          <div className="skills-grid">
            {Object.entries(skills).map(([category, values], index) => (
              <div className="card" key={index}>
                <h3>{category}</h3>

                <ul>
                  {values.map((skill, i) => (
                    <li key={i}>{skill}</li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="affiliations">
        <div className="container">
          <h2 className="section-title">Affiliations</h2>

          {affiliations.map((item, index) => (
            <div className="card" key={index}>
              <p>{item}</p>
            </div>
          ))}
        </div>
      </section>

      <section id="contact">
        <div className="container">
          <h2 className="section-title">Contact</h2>

          <div className="card">
            <p>Email: {profile.email}</p>
            <p>Phone: {profile.phone}</p>

            <div className="button-group">
              <a
                className="btn btn-primary"
                href={profile.linkedin}
                target="_blank"
              >
                LinkedIn
              </a>

              <a
                className="btn btn-secondary"
                href={profile.github}
                target="_blank"
              >
                GitHub
              </a>

              <a
                className="btn btn-secondary"
                href={profile.researchgate}
                target="_blank"
              >
                ResearchGate
              </a>

              <a
                className="btn btn-secondary"
                href={profile.googlescholar}
                target="_blank"
              >
                Google Scholar
              </a>
            </div>
          </div>
        </div>
      </section>

      <footer className="footer">
        <p>
          © 2026 MD. ZIADUL KARIM | Lecturer in Electrical and Electronic
          Engineering
        </p>
      </footer>
    </>
  );
}

export default App;

import React from 'react'
import ReactDOM from 'react-dom/client'
import App from './App'
import './index.css'

ReactDOM.createRoot(document.getElementById('root')).render(
  <React.StrictMode>
    <App />
  </React.StrictMode>,
)
